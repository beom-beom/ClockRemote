<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LED 시계 스마트 리모컨"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"
        android:textColor="#333333"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">
        <Button android:id="@+id/btnSet" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:text="설정 (SET)" android:layout_margin="5dp" android:backgroundTint="#607D8B"/>
        <Button android:id="@+id/btnOk" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:text="확인 (OK)" android:layout_margin="5dp" android:backgroundTint="#455A64"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:weightSum="2">
        <Button android:id="@+id/btnPlus" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:text="+ 1초/단위" android:layout_margin="5dp" android:backgroundTint="#2196F3"/>
        <Button android:id="@+id/btnMinus" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:text="- 1초/단위" android:layout_margin="5dp" android:backgroundTint="#F44336"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#DDDDDD" android:layout_marginVertical="30dp"/>

    <Button
        android:id="@+id/btnSync"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:text="현재 시간으로 자동 동기화"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="주의: 시계가 00:00일 때 실행하세요"
        android:textColor="#FF5722"
        android:textSize="13sp"/>

</LinearLayout>
